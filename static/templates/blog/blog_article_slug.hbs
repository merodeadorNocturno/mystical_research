<body>
    <div id="loading-overlay" class="loading-overlay">
        <div class="loading-spinner"></div>
    </div>

    {{> nav}}

    <section class="main_container">

        <!-- <aside class="ad-container">
            <div class="ad-content">
                <div class="ad-banner">Sponsored Content</div>
            </div>
        </aside> -->
        <!-- Main Content -->
        <main class="post-layout-grid">
            <article class="post-main">
                <!-- Header Section -->
                <header class="post-header-academic">
                    <div class="post-meta">
                        <span class="post-author">By {{article.author}}</span>
                    </div>
                    <h1 class="post-title">{{article.title}}</h1>
                    
                    {{#if keywords}}
                    <div class="post-tags">
                        {{#each keywords}}
                            <span class="tag">{{{this}}}</span>
                        {{/each}}
                    </div>
                    {{/if}}
                </header>

                <!-- Featured Image -->
                {{#if article.image_urls}}
                <figure class="post-featured-image">
                    <img src="/static/img/{{article.image_urls}}" alt="{{article.title}}" loading="lazy" />
                </figure>
                {{/if}}

                <!-- Abstract -->
                <section class="post-abstract">
                    <h3 class="abstract-title">Abstract</h3>
                    <p>
                        {{{article.summary}}}
                    </p>
                </section>

                <!-- In-Content Ad 1 -->
                <div class="in-content-ad">
                    <div class="ad-content">
                        <div class="ad-banner">Advertisement</div>
                    </div>
                </div>

                <!-- Academic Content Body with Editorial styling -->
                <section class="post-content editorial">
                    {{{article.content}}}
                </section>

                <!-- In-Content Ad 2 -->
                <div class="in-content-ad">
                    <div class="ad-content">
                        <div class="ad-banner">Advertisement</div>
                    </div>
                </div>

            </article>

            <!-- Sidebar -->
            <aside class="post-sidebar">
                <!-- Sidebar Ad -->
                <div class="sidebar-ad-container">
                    <div class="ad-content">
                        <div class="ad-banner">Advertisement</div>
                    </div>
                </div>

                <!-- Author Profile in Sidebar -->
                <div class="sidebar-widget sidebar-author">
                    <img src="/static/img/avatar2.png" alt="{{article.author}}" loading="lazy" />
                    <h4>{{article.author}}</h4>
                    <p class="author-role">Resident Scholar</p>
                </div>

                <!-- Table of Contents in Sidebar -->
                {{#if table_of_contents}}
                <div class="sidebar-widget post-toc">
                    <h3>Contents</h3>
                    <ul>
                        {{#each table_of_contents}}
                            <li><a href="#{{this}}">{{{this}}}</a></li>
                        {{/each}}
                    </ul>
                </div>
                {{/if}}
                
            </aside>
        </main>
    </section>

    <section class="newsletter" id="newsletter_form_container">
    {{> newsletter_section }}
    </section>

    {{> footer}}

    <script>
      document.addEventListener('htmx:beforeRequest', function(event) {
        const loadingOverlay = document.getElementById('loading-overlay');
        if (loadingOverlay) {
          loadingOverlay.style.display = 'block'; // Show loading overlay
        }
      });

      document.addEventListener('htmx:afterSettle', function(event) {
        const loadingOverlay = document.getElementById('loading-overlay');
        if (loadingOverlay) {
          loadingOverlay.style.display = 'none'; // Hide loading overlay after content is loaded
        }
      });

      document.addEventListener('htmx:responseError', function(event) {
        const loadingOverlay = document.getElementById('loading-overlay');
        if (loadingOverlay) {
          loadingOverlay.style.display = 'none'; // Hide loading overlay on error as well
        }
      });
    </script>

</body>
